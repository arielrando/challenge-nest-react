# Copiá este archivo a `.env` en la raíz del repo (junto a docker-compose.yml):
#   cp .env.example .env
# No subas `.env` al git (está en .gitignore).

# ─── Docker Compose (Postgres + API + proxy del frontend) ───────────────────
POSTGRES_USER=hassan
POSTGRES_PASSWORD=password
POSTGRES_PUBLISHED_PORT=5432

DATABASE_NAME=ecommercedb
# Debe coincidir con init.sql (CREATE DATABASE) salvo que lo cambies allí también.

API_PUBLISHED_PORT=3000
FRONTEND_PUBLISHED_PORT=5173

# Destino del proxy de Vite (red Docker: hostname del servicio `api`)
API_PROXY_TARGET=http://api:3000

# API Nest (sobrescribe/acompaña lo que cargue Config desde common/envs)
JWT_SECRET=keep-this-secret-private
# Frontend público permitido para CORS (separar múltiples por coma)
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ─── Nest local (sin Docker: copiá también a src/common/envs/development.env si preferís) ───
PORT=3000
BASE_URL=http://localhost:3000
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_ENTITIES=dist/**/*.entity.{ts,js}
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=12345678

# ─── Frontend (Vite): solo variables con prefijo VITE_ ───────────────────────
# ⚠️ Cualquier VITE_* se incluye en el JavaScript que baja al navegador.
#    No pongas contraseñas reales de usuarios finales aquí.
FRONTEND_DEV_PORT=5173
# URL pública del backend para deploy (dejar vacío en local con proxy de Vite)
VITE_API_BASE_URL=

VITE_DEMO_DEFAULT_EMAIL=
VITE_DEMO_DEFAULT_PASSWORD=
VITE_DEMO_CATEGORY_ID=1

VITE_DEMO_TITLE=Producto demo
VITE_DEMO_CODE=DEMO-FE-001
VITE_DEMO_VARIATION_TYPE=NONE
VITE_DEMO_DESCRIPTION=Creado desde el frontend de prueba
VITE_DEMO_ABOUT_LINE=Demostración punta a punta

VITE_DEMO_DETAIL_CATEGORY=Computers
VITE_DEMO_DETAIL_CAPACITY=512
VITE_DEMO_DETAIL_CAPACITY_UNIT=GB
VITE_DEMO_DETAIL_CAPACITY_TYPE=SSD
VITE_DEMO_DETAIL_BRAND=Acme
VITE_DEMO_DETAIL_SERIES=X1
